<mujoco model="arm">
    <!-- <compiler angle="radian" coordinate="local" meshdir="meshes"/> -->
    <compiler angle="radian" coordinate="local" meshdir="meshes" autolimits="true"/>
      <option timestep="0.001"/> 
      <option solver="Newton" iterations="50" tolerance="1e-10"/>

    <!-- <option gravity="0 0 -9.81" integrator="RK4"/> -->

    <asset>
        <mesh name="base_link_mesh" file="base_link.STL" scale="1 1 1"/>
        <mesh name="shoulder_link_mesh" file="shoulder_link.STL" scale="1 1 1"/>
        <mesh name="elbow_link_mesh" file="elbow_link.STL" scale="1 1 1"/>
        <mesh name="wrist_link1_mesh" file="wrist_link1.STL" scale="1 1 1"/>
        <mesh name="wrist_link2_mesh" file="wrist_link2.STL" scale="1 1 1"/>
        <mesh name="wrist_link3_mesh" file="wrist_link3.STL" scale="1 1 1"/>
    </asset>

    <worldbody>
        <!-- Base -->
        <body name="base_link" pos="0 0 0">
            <inertial pos="0.9401 0.68999 1.6254"
                      mass="0.69063"
                      diaginertia="0.0019945 0.0023444 0.0018065"/>

            <geom type="mesh" mesh="base_link_mesh" contype="0" conaffinity="0" group="1" rgba="0.79216 0.81961 0.93333 1"/>
            <!-- <joint type="fixed"/> -->

            <!-- Shoulder -->
            <body name="shoulder_link"
                  pos="0.94721 -1.6052 0.73686"
                  euler="1.5708 0.12264 -0.33837">

                <joint name="joint0"
                       type="hinge"
                       axis="0 0 1"
                       range="-1.57 1.57"
                       damping="0.2"
                       armature="0.01"
                       frictionloss="0.01"/>

                <inertial pos="2.3204E-13 0.19201 0.021452"
                          mass="0.52909"
                          diaginertia="0.0083742 0.00067881 0.0085718"/>

                <geom type="mesh" mesh="shoulder_link_mesh" contype="0" conaffinity="0" group="1" rgba="0.79216 0.81961 0.93333 1"/>

                <!-- Elbow -->
                <body name="elbow_link"
                      pos="0 0.37 0"
                      euler="0 0 -1.0913">

                    <joint name="joint1"
                           type="hinge"
                           axis="0 0 1"
                           range="-2.35 2.35"
                           damping="0.2"
                           armature="0.01"
                           frictionloss="0.01"/>

                    <inertial pos="-0.00040915 0.060791 -0.040286"
                              mass="0.30405"
                              diaginertia="0.001555 0.00042147 0.0014937"/>

                    <geom type="mesh" mesh="elbow_link_mesh"
                          rgba="0.79216 0.81961 0.93333 1"/>

                    <!-- Wrist 1 -->
                    <body name="wrist_link1"
                          pos="0 0.07405 -0.04106"
                          euler="0 0.87591 0">

                        <joint name="joint3"
                               type="hinge"
                               axis="0 1 0"
                               range="-2.35 2.35"
                               damping="0.2"
                               armature="0.01"
                               frictionloss="0.01"/>

                        <inertial pos="8.96158792158541E-05 0.133468259482244 -0.000295926857309836"
                                  mass="0.336426291824284"
                                  diaginertia="0.00152881099917185 0.00035171540397663 0.00158086128910011"/>

                        <geom type="mesh" mesh="wrist_link1_mesh" contype="0" conaffinity="0" group="1" rgba="0.79216 0.81961 0.93333 1"/>

                        <!-- Wrist 2 -->
                        <body name="wrist_link2"
                              pos="0 0.21394 0"
                              euler="-1.5708 0.19832 1.5708">

                            <joint name="joint4"
                                   type="hinge"
                                   axis="0 0 1"
                                   range="-2.35 2.35"
                                   damping="0.2"
                                   armature="0.01"
                                   frictionloss="0.01"/>

                            <inertial pos="0.053266 1.9073E-12 2.025E-13"
                                      mass="0.27316"
                                      diaginertia="0.00011138 0.00044491 0.00045088"/>

                            <geom type="mesh" mesh="wrist_link2_mesh" contype="0" conaffinity="0" group="1" rgba="0.79216 0.81961 0.93333 1"/>

                            <!-- Wrist 3 -->
                            <body name="wrist_link3"
                                  pos="0.102 0 0"
                                  euler="2.6957 -1.5708 0">

                                <joint name="joint5"
                                       type="hinge"
                                       axis="1 0 0"
                                       range="-2.35 2.35"
                                       damping="0.2"
                                       armature="0.01"
                                       frictionloss="0.01"/>

                                <inertial pos="-0.00094552 -0.00036859 0.080166"
                                          mass="0.16588"
                                          diaginertia="4.4169E-05 5.5852E-05 3.238E-05"/>

                                <geom type="mesh" mesh="wrist_link3_mesh" contype="0" conaffinity="0" group="1" rgba="0.79216 0.81961 0.93333 1"/>
                            </body>

                        </body>
                    </body>
                </body>
            </body>
        </body>

    </worldbody>
</mujoco>